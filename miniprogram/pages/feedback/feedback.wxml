<!--反馈页面-->
<view class="container">
  <view class="header">
    <text class="title">📝 意见反馈</text>
    <text class="subtitle">您的反馈将帮助我们不断改进</text>
  </view>

  <!-- 问题列表 -->
  <view class="questions">
    <view class="question-item" wx:for="{{questions}}" wx:key="id">
      <text class="question-text">{{index + 1}}. {{item.question}}</text>
      
      <!-- 评分类型 -->
      <view class="rating-input" wx:if="{{item.type === 'rating'}}">
        <slider min="1" max="5" value="{{item.value || 3}}" 
                show-value 
                activeColor="#8B0000"
                data-question-id="{{item.id}}"
                bindchange="onRatingChange"/>
        <view class="rating-labels">
          <text>很差</text>
          <text>一般</text>
          <text>很好</text>
        </view>
      </view>

      <!-- 选择类型 -->
      <radio-group class="choice-input" wx:if="{{item.type === 'choice'}}" 
                   data-question-id="{{item.id}}"
                   bindchange="onChoiceChange">
        <label class="choice-item" wx:for="{{item.options}}" wx:for-item="option" wx:key="*this">
          <radio value="{{option}}" color="#8B0000" checked="{{item.value === option}}"/>
          <text>{{option}}</text>
        </label>
      </radio-group>

      <!-- 文本类型 -->
      <textarea class="text-input" wx:if="{{item.type === 'text'}}"
                placeholder="请输入您的回答..."
                value="{{item.value}}"
                data-question-id="{{item.id}}"
                bindinput="onTextInput"/>
    </view>
  </view>

  <!-- 图片上传 -->
  <view class="image-section">
    <text class="section-title">📷 上传截图（可选）</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image class="preview-image" src="{{item}}" mode="aspectFill"/>
        <view class="remove-btn" data-index="{{index}}" bindtap="onRemoveImage">✕</view>
      </view>
      <view class="add-image" wx:if="{{images.length < 3}}" bindtap="onChooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 查看学习报告 -->
  <view class="report-entry" bindtap="onViewLearningReport">
    <text class="report-icon">📊</text>
    <view class="report-info">
      <text class="report-text">查看我的学习报告</text>
      <text class="report-desc">AI分析您的学习数据</text>
    </view>
    <text class="report-arrow">></text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>

  <!-- 报告弹窗 -->
  <view class="report-modal" wx:if="{{showReport}}">
    <view class="modal-mask" bindtap="onCloseReport"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">📊 AI学习报告</text>
        <text class="modal-close" bindtap="onCloseReport">✕</text>
      </view>
      <scroll-view class="report-body" scroll-y>
        <view class="report-loading" wx:if="{{generatingReport}}">
          <view class="loading-spinner"></view>
          <text>AI正在分析您的学习数据...</text>
        </view>
        <view class="report-text-content" wx:else>
          <text>{{report}}</text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="share-btn" bindtap="onShareReport">分享报告</button>
        <button class="confirm-btn" bindtap="onCloseReport">关闭</button>
      </view>
    </view>
  </view>
</view>