<!--游戏房间页面-->
<view class="container">
  <!-- 等待中状态 -->
  <block wx:if="{{roomStatus === 'waiting'}}">
    <!-- 房间信息 -->
    <view class="room-header">
      <view class="room-info">
        <text class="room-title">{{scriptTitle || '游戏房间'}}</text>
        <view class="room-id" bindtap="onCopyRoomId">
          <text>房间号：{{roomId}}</text>
          <text class="copy-btn">复制</text>
        </view>
      </view>
      <button class="share-btn" open-type="share">邀请好友</button>
    </view>

    <!-- 玩家列表 -->
    <view class="players-section">
      <view class="section-title">玩家列表 ({{players.length}}/{{maxPlayers}})</view>
      <view class="players-grid">
        <view class="player-slot" wx:for="{{maxPlayers}}" wx:key="*this">
          <block wx:if="{{players[index]}}">
            <view class="player-card {{players[index].isReady ? 'ready' : ''}}">
              <image class="player-avatar" src="{{players[index].avatar || '/assets/images/default-avatar.jpg'}}" mode="aspectFill"/>
              <text class="player-name">{{players[index].name}}</text>
              <text class="player-role" wx:if="{{players[index].roleName}}">{{players[index].roleName}}</text>
              <view class="player-status">
                <text wx:if="{{players[index].isHost}}" class="host-badge">房主</text>
                <text wx:elif="{{players[index].isReady}}" class="ready-badge">已准备</text>
                <text wx:else class="waiting-badge">等待中</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="empty-slot">
              <text class="empty-icon">+</text>
              <text class="empty-text">等待加入</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 角色选择 -->
    <view class="role-section">
      <view class="section-title">选择角色</view>
      <view class="selected-role" bindtap="onShowRoleSelect">
        <block wx:if="{{selectedRoleId}}">
          <text class="role-name">已选择角色</text>
          <text class="change-btn">更换</text>
        </block>
        <block wx:else>
          <text class="select-hint">点击选择角色</text>
        </block>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <view class="action-btn leave" bindtap="onLeaveRoom">离开房间</view>
      <block wx:if="{{isHost}}">
        <view class="action-btn start {{players.length >= 2 ? '' : 'disabled'}}" bindtap="onStartGame">开始游戏</view>
      </block>
      <block wx:else>
        <view class="action-btn ready {{isReady ? 'cancel' : ''}}" bindtap="onToggleReady">
          {{isReady ? '取消准备' : '准备'}}
        </view>
      </block>
    </view>
  </block>

  <!-- 游戏进行中 -->
  <block wx:if="{{roomStatus === 'playing'}}">
    <!-- 场景展示 -->
    <view class="scene-section" wx:if="{{currentScene}}">
      <view class="scene-header">
        <text class="scene-name">📍 {{currentScene.name}}</text>
      </view>
      <view class="scene-content">
        <text class="scene-desc">{{currentScene.description}}</text>
      </view>
      
      <!-- NPC列表 -->
      <view class="npc-list" wx:if="{{currentScene.npcs.length > 0}}">
        <view class="npc-title">场景中的人物</view>
        <view class="npc-item" 
              wx:for="{{currentScene.npcs}}" 
              wx:key="id"
              data-npc-id="{{item.id}}"
              bindtap="onTalkToNPC">
          <view class="npc-avatar">👤</view>
          <view class="npc-info">
            <text class="npc-name">{{item.name}}</text>
            <text class="npc-role">{{item.role}}</text>
          </view>
          <text class="talk-btn">对话</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="game-actions">
      <view class="game-action-btn" bindtap="onViewClues">
        <text class="action-icon">📋</text>
        <text>线索本</text>
      </view>
    </view>
  </block>

  <!-- 角色选择弹窗 -->
  <view class="role-modal" wx:if="{{showRoleSelect}}">
    <view class="modal-mask" bindtap="onCloseRoleSelect"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择角色</text>
        <text class="modal-close" bindtap="onCloseRoleSelect">✕</text>
      </view>
      <view class="role-list">
        <view class="role-item {{item.isSelected ? 'disabled' : ''}} {{selectedRoleId === item.id ? 'selected' : ''}}" 
              wx:for="{{roles}}" 
              wx:key="id"
              data-role-id="{{item.id}}"
              bindtap="onSelectRole">
          <view class="role-avatar">{{item.name[0]}}</view>
          <view class="role-info">
            <text class="role-name">{{item.name}}</text>
            <text class="role-desc">{{item.description}}</text>
          </view>
          <text class="role-status" wx:if="{{item.isSelected}}">已被选</text>
        </view>
      </view>
    </view>
  </view>
</view>