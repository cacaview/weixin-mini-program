<!--NPC对话页面-->
<view class="container">
  <!-- 顶部NPC信息栏 -->
  <view class="npc-header">
    <view class="npc-info">
      <image class="npc-avatar" src="{{npc.avatar}}" mode="aspectFill"/>
      <view class="npc-detail">
        <text class="npc-name">{{npc.name}}</text>
        <text class="npc-role">{{npc.role}}</text>
      </view>
    </view>
    <view class="header-actions">
      <view class="action-btn" bindtap="onViewClues">
        <text>📋 线索本</text>
      </view>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-area" 
               scroll-y="{{true}}" 
               scroll-into-view="{{scrollToView}}"
               scroll-with-animation="{{true}}"
               enhanced="{{true}}"
               show-scrollbar="{{false}}">
    <view class="chat-list">
      <view class="message-item {{item.role}}" 
            wx:for="{{messages}}" 
            wx:key="id"
            id="{{item.id}}">
        <!-- 系统消息 -->
        <view class="system-message" wx:if="{{item.role === 'system'}}">
          <text class="system-text">{{item.content}}</text>
        </view>

        <!-- NPC消息 -->
        <view class="npc-message" wx:elif="{{item.role === 'npc'}}">
          <image class="message-avatar" src="{{npc.avatar}}" mode="aspectFill"/>
          <view class="message-bubble npc-bubble">
            <view class="loading-dots" wx:if="{{item.isLoading}}">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
            <text class="message-text" wx:else>{{item.content}}</text>
          </view>
        </view>

        <!-- 用户消息 -->
        <view class="user-message" wx:elif="{{item.role === 'user'}}">
          <view class="message-bubble user-bubble">
            <image class="message-image" 
                   wx:if="{{item.imageUrl}}" 
                   src="{{item.imageUrl}}" 
                   mode="aspectFill"
                   data-url="{{item.imageUrl}}"
                   bindtap="onPreviewImage"/>
            <text class="message-text" wx:if="{{item.content}}">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷问题 -->
    <view class="quick-questions" wx:if="{{messages.length <= 3}}">
      <text class="quick-title">你可以问：</text>
      <view class="quick-list">
        <view class="quick-item" 
              data-question="您好，请问您是做什么的？" 
              bindtap="onQuickQuestion">
          您好，请问您是做什么的？
        </view>
        <view class="quick-item" 
              data-question="这些剪纸真漂亮，有什么特殊含义吗？" 
              bindtap="onQuickQuestion">
          这些剪纸真漂亮，有什么特殊含义吗？
        </view>
        <view class="quick-item" 
              data-question="我听说您以前帮助过地下党？" 
              bindtap="onQuickQuestion">
          我听说您以前帮助过地下党？
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="chat-bottom-space"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area" style="padding-bottom: {{keyboardHeight}}px;">
    <!-- 已选图片预览 -->
    <view class="selected-image-wrap" wx:if="{{selectedImage}}">
      <image class="selected-image" src="{{selectedImage}}" mode="aspectFill"/>
      <view class="remove-image" bindtap="onRemoveImage">✕</view>
    </view>
    
    <view class="input-row">
      <!-- 图片按钮 -->
      <view class="input-btn image-btn {{!supportImage ? 'disabled' : ''}}" bindtap="onChooseImage">
        <text>🖼️</text>
      </view>
      
      <!-- 文字输入 -->
      <input class="text-input" 
             placeholder="输入你想说的话..." 
             value="{{inputText}}"
             bindinput="onInputChange"
             bindconfirm="onSendMessage"
             confirm-type="send"
             adjust-position="{{false}}"/>
      
      <!-- 发送按钮 -->
      <view class="input-btn send-btn {{sending ? 'disabled' : ''}}" bindtap="onSendMessage">
        <text>发送</text>
      </view>
    </view>
  </view>

  <!-- 线索获得弹窗 -->
  <view class="clue-modal" wx:if="{{showClueModal}}">
    <view class="clue-modal-mask" bindtap="onCloseClueModal"></view>
    <view class="clue-modal-content">
      <view class="clue-modal-header">
        <text class="clue-modal-title">🎉 获得新线索！</text>
      </view>
      <view class="clue-list">
        <view class="clue-item" wx:for="{{newClues}}" wx:key="id">
          <image class="clue-image" 
                 wx:if="{{item.imageUrl}}" 
                 src="{{item.imageUrl}}" 
                 mode="aspectFill"/>
          <view class="clue-info">
            <text class="clue-name">{{item.name}}</text>
            <text class="clue-desc">{{item.description}}</text>
          </view>
        </view>
      </view>
      <view class="clue-modal-footer">
        <button class="clue-confirm-btn" bindtap="onCloseClueModal">知道了</button>
      </view>
    </view>
  </view>
</view>