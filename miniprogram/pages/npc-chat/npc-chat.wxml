<!--NPC对话页面-->
<view class="container">
  <!-- 顶部NPC信息栏 -->
  <view class="npc-header">
    <view class="npc-info">
      <image class="npc-avatar" src="{{npc.avatar}}" mode="aspectFill"/>
      <view class="npc-detail">
        <text class="npc-name">{{npc.name}}</text>
        <text class="npc-role">{{npc.role}}</text>
      </view>
    </view>
    <view class="header-actions">
      <view class="action-btn" bindtap="onBackToGame">
        <text>返回</text>
      </view>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-area" 
               scroll-y="{{true}}" 
               scroll-into-view="{{scrollToView}}"
               scroll-with-animation="{{true}}"
               enhanced="{{true}}"
               show-scrollbar="{{false}}">
    <view class="chat-list">
      <view class="message-item {{item.role}}" 
            wx:for="{{messages}}" 
            wx:key="id"
            id="{{item.id}}">
        <!-- 系统消息 -->
        <view class="system-message" wx:if="{{item.role === 'system'}}">
          <text class="system-text">{{item.content}}</text>
        </view>

        <!-- NPC消息 -->
        <view class="npc-message" wx:elif="{{item.role === 'npc'}}">
          <image class="message-avatar" src="{{npc.avatar}}" mode="aspectFill"/>
          <view class="message-bubble npc-bubble">
            <view class="loading-dots" wx:if="{{item.isLoading}}">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
            <text class="message-text" wx:else>{{item.content}}</text>
          </view>
        </view>

        <!-- 用户消息 -->
        <view class="user-message" wx:elif="{{item.role === 'user'}}">
          <view class="message-bubble user-bubble">
            <text class="message-text">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷问题 -->
    <view class="quick-questions" wx:if="{{messages.length <= 3}}">
      <text class="quick-title">你可以问：</text>
      <view class="quick-list">
        <view class="quick-item" 
              wx:for="{{quickQuestions}}"
              wx:key="*this"
              data-question="{{item}}" 
              bindtap="onQuickQuestion">
          {{item}}
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="chat-bottom-space"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-row">
      <!-- 文字输入 -->
      <input class="text-input" 
             placeholder="输入你想说的话..." 
             value="{{inputText}}"
             bindinput="onInputChange"
             bindconfirm="onSendMessage"
             confirm-type="send"
             disabled="{{sending}}"/>
      
      <!-- 发送按钮 -->
      <view class="input-btn send-btn {{sending ? 'disabled' : ''}}" bindtap="onSendMessage">
        <text wx:if="{{!sending}}">发送</text>
        <text wx:else>...</text>
      </view>
    </view>
  </view>
</view>