<!--剧本库页面-->
<view class="container">
  <!-- 搜索和筛选栏 -->
  <view class="search-filter-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" 
             placeholder="搜索剧本名称、主题..." 
             value="{{filters.keyword}}"
             bindinput="onSearchInput"
             bindconfirm="onSearchConfirm"/>
      <text class="clear-icon" wx:if="{{filters.keyword}}" bindtap="onClearSearch">✕</text>
    </view>
    <view class="filter-btn" bindtap="toggleFilterPanel">
      <text class="filter-icon">⚙️</text>
      <text>筛选</text>
    </view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view class="sort-item {{sortBy === 'latest' ? 'active' : ''}}" 
          data-sort="latest" 
          bindtap="onSortChange">
      最新发布
    </view>
    <view class="sort-item {{sortBy === 'popular' ? 'active' : ''}}" 
          data-sort="popular" 
          bindtap="onSortChange">
      最多游玩
    </view>
    <view class="sort-item {{sortBy === 'rating' ? 'active' : ''}}" 
          data-sort="rating" 
          bindtap="onSortChange">
      评分最高
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilterPanel ? 'show' : ''}}">
    <view class="filter-mask" bindtap="toggleFilterPanel"></view>
    <view class="filter-content">
      <view class="filter-header">
        <text class="filter-title">筛选条件</text>
        <text class="filter-reset" bindtap="resetFilters">重置</text>
      </view>
      
      <!-- 主题筛选 -->
      <view class="filter-group">
        <text class="filter-label">主题</text>
        <picker mode="selector" 
                range="{{themeOptions}}" 
                value="{{selectedThemeIndex}}"
                bindchange="onThemeChange">
          <view class="filter-picker">
            <text>{{themeOptions[selectedThemeIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 难度筛选 -->
      <view class="filter-group">
        <text class="filter-label">难度</text>
        <picker mode="selector" 
                range="{{difficultyOptions}}" 
                value="{{selectedDifficultyIndex}}"
                bindchange="onDifficultyChange">
          <view class="filter-picker">
            <text>{{difficultyOptions[selectedDifficultyIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 非遗元素筛选 -->
      <view class="filter-group">
        <text class="filter-label">非遗元素</text>
        <picker mode="selector" 
                range="{{heritageOptions}}" 
                value="{{selectedHeritageIndex}}"
                bindchange="onHeritageChange">
          <view class="filter-picker">
            <text>{{heritageOptions[selectedHeritageIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 人数筛选 -->
      <view class="filter-group">
        <text class="filter-label">游戏人数</text>
        <picker mode="selector" 
                range="{{playerCountOptions}}" 
                value="{{selectedPlayerCountIndex}}"
                bindchange="onPlayerCountChange">
          <view class="filter-picker">
            <text>{{playerCountOptions[selectedPlayerCountIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="filter-actions">
        <button class="filter-apply-btn" bindtap="applyFilters">应用筛选</button>
      </view>
    </view>
  </view>

  <!-- 剧本列表 -->
  <view class="script-list">
    <view class="script-card" 
          wx:for="{{scripts}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onScriptTap">
      <image class="script-cover" src="{{item.cover}}" mode="aspectFill"/>
      <view class="script-info">
        <text class="script-title">{{item.title}}</text>
        <text class="script-desc">{{item.description}}</text>
        <view class="script-tags">
          <text class="tag theme-tag">{{item.theme}}</text>
          <text class="tag heritage-tag" 
                wx:for="{{item.heritageElements}}" 
                wx:for-item="heritage" 
                wx:key="*this">{{heritage}}</text>
        </view>
        <view class="script-footer">
          <view class="script-meta">
            <text class="meta-item">👥 {{item.playerCount.min}}-{{item.playerCount.max}}人</text>
            <text class="meta-item">⏱️ {{item.duration}}分钟</text>
            <text class="meta-item difficulty-{{item.difficulty}}">
              {{item.difficulty === 'easy' ? '简单' : item.difficulty === 'medium' ? '中等' : '困难'}}
            </text>
          </view>
          <view class="script-stats">
            <text class="stat-item">⭐ {{item.rating}}</text>
            <text class="stat-item">🎮 {{item.playCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{scripts.length > 0}}">
    <view wx:if="{{loading}}" class="loading">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
    <text wx:elif="{{!hasMore}}" class="no-more">没有更多了</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && scripts.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无符合条件的剧本</text>
    <button class="empty-btn" bindtap="resetFilters">重置筛选</button>
  </view>
</view>